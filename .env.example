# Copy to .env in the repo root or backend/ and adjust.

# Local SQLite file at backend/triplogic.db — use either:
#   (A) Leave DATABASE_URL unset, or
#   (B) Set USE_LOCAL_SQLITE=1 (ignores DATABASE_URL; good when .env still has a remote URL).
# USE_LOCAL_SQLITE=1
#
# DATABASE_URL=

OPENAI_API_KEY=
# Optional override (default: gpt-5.4-mini)
# OPENAI_MODEL=gpt-5.4-mini

# Optional: itinerary tools (server-side only). If unset, the planner still builds an itinerary without live flight/place lookups.
# AviationStack: https://aviationstack.com/documentation — used for airport/city lookup only
AVIATIONSTACK_ACCESS_KEY=
# Google Places API (New): Text Search / Place Details — one key for server-side Places usage
GOOGLE_PLACES_API_KEY=
# SerpApi: Google Flights search — https://serpapi.com (100 free searches/month)
SERP_API_KEY=

FRONTEND_URL=http://localhost:8080

# Supabase (backend + frontend auth)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
